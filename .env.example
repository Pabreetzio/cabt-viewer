# Optional: required only for real local CABT play.
# Point this at the Kaggle-provided sample_submission directory.
CABT_SAMPLE_SUBMISSION_DIR=/absolute/path/to/sample_submission

# Optional: adds local agent build folders to the Play tab dropdown.
# If omitted, CABT_SAMPLE_SUBMISSION_DIR is also scanned for agent folders.
CABT_AGENT_DIR=/absolute/path/to/agent/builds

# Optional: adds local replay JSON files to the Game logs tab.
CABT_REPLAY_DIR=/absolute/path/to/replays
